# ─── Supabase (get from supabase.com → Settings → API) ───────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── WAHA (your Railway WAHA service internal URL) ────────────────────────────
WAHA_BASE_URL=http://waha.railway.internal:3000
WAHA_API_KEY=replace-with-your-waha-secret-key

# ─── Slack (get from api.slack.com/apps) ─────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Set this to your Railway app URL after first deploy
APP_URL=http://localhost:3000
